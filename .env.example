BOT_TOKEN=your_telegram_bot_token_here

# AI provider (openai, anthropic, or ai_gateway) — for image generation tools on the bot side
AI_PROVIDER=openai
# Model ID (defaults vary by provider: gpt-4o-mini / claude-sonnet-4 / openai/gpt-4o-mini)
AI_MODEL_ID=

# Provider API keys (set the one matching your AI_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=

# Internal API keys (auto-generated for Docker, set manually for local dev)
BOT_TOOL_API_KEY=
SANDBOX_API_KEY=

# Docker Agent URL (when running outside Docker)
# DOCKER_AGENT_URL=http://localhost:8080
