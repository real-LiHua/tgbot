BOT_TOKEN=your_telegram_bot_token_here

# AI provider (openai, anthropic, or ai_gateway)
AI_PROVIDER=openai
# Model ID (defaults vary by provider: gpt-4o-mini / claude-sonnet-4 / openai/gpt-4o-mini)
AI_MODEL_ID=

# Provider API keys (set the one matching your AI_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=

# Internal API keys (auto-generated for Docker, set manually for local dev)
AI_SERVICE_API_KEY=
SANDBOX_API_KEY=

# AI Service URL (when running outside Docker)
# AI_SERVICE_URL=http://localhost:8000
